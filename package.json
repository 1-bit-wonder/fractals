{
  "name": "fractals",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "1-bit fractal avatar generator (TypeScript + AssemblyScript/WASM)",
  "scripts": {
    "build:wasm": "asc assembly/index.ts --config asconfig.json --target release",
    "build:wasm:debug": "asc assembly/index.ts --config asconfig.json --target debug",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:wasm && npm run build:ts",
    "watch": "tsc -p tsconfig.json --watch",
    "serve": "node serve.mjs",
    "dev": "npm run build && node serve.mjs"
  },
  "devDependencies": {
    "assemblyscript": "^0.27.31",
    "typescript": "^5.6.3"
  }
}
